{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "BackendConfig": {
      "properties": {
        "type": {
          "default": "local",
          "description": "Backend type identifier (e.g. `local`, `gcs`). Defaults to `local`.",
          "type": "string"
        }
      },
      "type": "object"
    },
    "NotifyConfig": {
      "properties": {
        "slack": {
          "anyOf": [
            {
              "$ref": "#/definitions/SlackConfig"
            },
            {
              "type": "null"
            }
          ],
          "description": "Slack notification settings. When set, notifications are sent to the specified channel."
        }
      },
      "type": "object"
    },
    "SlackConfig": {
      "properties": {
        "channel": {
          "description": "Slack channel to send notifications to (e.g. `#nagi-alerts`).",
          "type": "string"
        }
      },
      "required": [
        "channel"
      ],
      "type": "object"
    }
  },
  "properties": {
    "backend": {
      "allOf": [
        {
          "$ref": "#/definitions/BackendConfig"
        }
      ],
      "description": "State storage backend configuration."
    },
    "notify": {
      "allOf": [
        {
          "$ref": "#/definitions/NotifyConfig"
        }
      ],
      "description": "Notification channel configuration."
    },
    "terminationGracePeriodSeconds": {
      "description": "Maximum time in seconds to wait for in-flight sync tasks to finish during shutdown. When omitted, waits indefinitely.",
      "format": "uint64",
      "minimum": 0.0,
      "type": [
        "integer",
        "null"
      ]
    }
  },
  "title": "NagiConfig",
  "type": "object"
}