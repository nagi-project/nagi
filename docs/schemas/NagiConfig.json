{
  "$defs": {
    "BackendConfig": {
      "properties": {
        "bucket": {
          "description": "Bucket name for GCS or S3 backend. Required when type is `gcs` or `s3`.",
          "type": [
            "string",
            "null"
          ]
        },
        "prefix": {
          "description": "Path prefix for remote storage (e.g. `my-project/nagi`). When set, all\nremote paths are prefixed with this value. Ignored for the local backend.",
          "type": [
            "string",
            "null"
          ]
        },
        "region": {
          "description": "AWS region for S3 backend (e.g. `us-east-1`). Required when type is `s3`.",
          "type": [
            "string",
            "null"
          ]
        },
        "type": {
          "$ref": "#/$defs/BackendType",
          "description": "Backend type. Defaults to `local`."
        }
      },
      "type": "object"
    },
    "BackendType": {
      "enum": [
        "local",
        "gcs",
        "s3"
      ],
      "type": "string"
    },
    "Duration": {
      "description": "A human-readable duration string (e.g. \"24h\", \"30m\", \"1h30m\").",
      "format": "duration",
      "type": "string"
    },
    "ExportConfig": {
      "description": "Configuration for exporting logs to a remote data warehouse.",
      "properties": {
        "connection": {
          "description": "Reference to a `kind: Connection` resource name.",
          "type": "string"
        },
        "dataset": {
          "description": "Data warehouse dataset (BigQuery) or schema (Snowflake) to export into.",
          "type": "string"
        },
        "format": {
          "$ref": "#/$defs/ExportFormat",
          "default": "jsonl",
          "description": "Intermediate file format for export."
        },
        "interval": {
          "$ref": "#/$defs/Duration",
          "default": "30m",
          "description": "Condition evaluation interval and export throttling threshold."
        },
        "timeout": {
          "anyOf": [
            {
              "$ref": "#/$defs/Duration"
            },
            {
              "type": "null"
            }
          ],
          "description": "Timeout for export operations. Falls back to `defaultTimeout` when omitted."
        }
      },
      "required": [
        "connection",
        "dataset"
      ],
      "type": "object"
    },
    "ExportFormat": {
      "description": "Export format for log data.",
      "enum": [
        "jsonl",
        "duckdb"
      ],
      "type": "string"
    },
    "NotifyConfig": {
      "properties": {
        "slack": {
          "anyOf": [
            {
              "$ref": "#/$defs/SlackConfig"
            },
            {
              "type": "null"
            }
          ],
          "description": "Slack notification settings. When set, notifications are sent to the specified channel."
        }
      },
      "type": "object"
    },
    "SlackConfig": {
      "properties": {
        "channel": {
          "description": "Slack channel to send notifications to (e.g. `#nagi-alerts`).",
          "type": "string"
        }
      },
      "required": [
        "channel"
      ],
      "type": "object"
    },
    "StateDir": {
      "description": "State directory path. Contains logs, cache, locks, and other runtime data.\nProvides accessors for all well-known subdirectories.\n\nDeserializes from a plain string path (e.g. `\"~/.nagi\"` in YAML).",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Project configuration that is stored in the remote backend.\nContains all settings except `backend` (which is local-only).",
  "properties": {
    "backend": {
      "$ref": "#/$defs/BackendConfig",
      "description": "State storage backend configuration."
    },
    "defaultTimeout": {
      "$ref": "#/$defs/Duration",
      "default": "1h"
    },
    "export": {
      "anyOf": [
        {
          "$ref": "#/$defs/ExportConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "lockRetryIntervalSeconds": {
      "default": 900,
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "lockRetryMaxAttempts": {
      "default": 3,
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "lockTtlSeconds": {
      "default": 3600,
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "maxControllers": {
      "default": null,
      "format": "uint",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "maxEvaluateConcurrency": {
      "default": null,
      "format": "uint",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "maxSyncConcurrency": {
      "default": null,
      "format": "uint",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "notify": {
      "$ref": "#/$defs/NotifyConfig",
      "default": {
        "slack": null
      }
    },
    "stateDir": {
      "$ref": "#/$defs/StateDir",
      "default": "~/.nagi"
    },
    "terminationGracePeriodSeconds": {
      "default": null,
      "format": "uint64",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    }
  },
  "title": "NagiConfig",
  "type": "object"
}