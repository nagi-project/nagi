{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AssetSpec": {
      "description": "Spec for `kind: Asset`. The core resource: declares desired state and convergence operations. `on_drift` pairs conditions with sync operations. Entries are evaluated in order (first-match).",
      "properties": {
        "autoSync": {
          "default": true,
          "description": "Controls automatic sync execution in `nagi serve`. Defaults to `true`.",
          "type": "boolean"
        },
        "connection": {
          "default": null,
          "description": "Name of the Connection resource for DB access.",
          "type": [
            "string",
            "null"
          ]
        },
        "evaluateCacheTtl": {
          "anyOf": [
            {
              "$ref": "#/definitions/Duration"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Default evaluate cache TTL for all conditions in this Asset. Conditions can override this with their own `evaluateCacheTtl`."
        },
        "onDrift": {
          "default": [],
          "description": "Condition-sync pairs evaluated in order. First entry whose conditions detect drift determines which sync to run. When omitted, the Asset is always Ready.",
          "items": {
            "$ref": "#/definitions/OnDriftEntry"
          },
          "type": "array"
        },
        "tags": {
          "default": [],
          "description": "Tags for filtering with `--select tag:X`.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "upstreams": {
          "default": [],
          "description": "Names of upstream Asset resources.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "ConditionsSpec": {
      "description": "Spec for `kind: Conditions`. A reusable set of conditions referenced from Asset `onDrift` entries.",
      "items": {
        "$ref": "#/definitions/DesiredCondition"
      },
      "type": "array"
    },
    "ConnectionSpec": {
      "description": "Spec for `kind: Connection`. Holds external data connection info referenced by Assets.",
      "oneOf": [
        {
          "description": "Connection resolved via dbt profiles.yml.",
          "properties": {
            "dbtCloud": {
              "anyOf": [
                {
                  "$ref": "#/definitions/DbtCloudSpec"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional dbt Cloud configuration for running-job checks before sync."
            },
            "profile": {
              "description": "Profile name as defined in `~/.dbt/profiles.yml`.",
              "type": "string"
            },
            "profilesDir": {
              "description": "Directory containing profiles.yml. If omitted, uses `~/.dbt/`.",
              "type": [
                "string",
                "null"
              ]
            },
            "target": {
              "description": "If omitted, the default target in profiles.yml is used.",
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "enum": [
                "dbt"
              ],
              "type": "string"
            }
          },
          "required": [
            "profile",
            "type"
          ],
          "type": "object"
        },
        {
          "description": "BigQuery REST API connection.",
          "properties": {
            "dataset": {
              "description": "BigQuery dataset name.",
              "type": "string"
            },
            "executionProject": {
              "description": "GCP project ID used for query execution billing. Defaults to `project` if omitted.",
              "type": [
                "string",
                "null"
              ]
            },
            "keyfile": {
              "description": "Path to the service account JSON key file. Required when `method` is `service-account`.",
              "type": [
                "string",
                "null"
              ]
            },
            "method": {
              "description": "Authentication method. `oauth` (Application Default Credentials) or `service-account`. Defaults to `oauth`.",
              "type": [
                "string",
                "null"
              ]
            },
            "project": {
              "description": "GCP project ID that contains the dataset.",
              "type": "string"
            },
            "timeoutSeconds": {
              "description": "Query timeout in seconds.",
              "format": "uint32",
              "minimum": 0.0,
              "type": [
                "integer",
                "null"
              ]
            },
            "type": {
              "enum": [
                "bigquery"
              ],
              "type": "string"
            }
          },
          "required": [
            "dataset",
            "project",
            "type"
          ],
          "type": "object"
        },
        {
          "description": "DuckDB connection via the `duckdb` CLI.",
          "properties": {
            "path": {
              "description": "Path to the DuckDB database file.",
              "type": "string"
            },
            "type": {
              "enum": [
                "duckdb"
              ],
              "type": "string"
            }
          },
          "required": [
            "path",
            "type"
          ],
          "type": "object"
        },
        {
          "description": "Snowflake SQL REST API connection with Key-Pair JWT authentication.",
          "properties": {
            "account": {
              "description": "Snowflake account identifier (e.g. `myorg-myaccount`).",
              "type": "string"
            },
            "database": {
              "description": "Database name.",
              "type": "string"
            },
            "privateKeyPath": {
              "description": "Path to the RSA private key file (PKCS#8 PEM format) for JWT authentication.",
              "type": "string"
            },
            "role": {
              "description": "Role to use for the session. Uses the user's default role if omitted.",
              "type": [
                "string",
                "null"
              ]
            },
            "schema": {
              "description": "Schema name.",
              "type": "string"
            },
            "type": {
              "enum": [
                "snowflake"
              ],
              "type": "string"
            },
            "user": {
              "description": "Snowflake login user name.",
              "type": "string"
            },
            "warehouse": {
              "description": "Warehouse name.",
              "type": "string"
            }
          },
          "required": [
            "account",
            "database",
            "privateKeyPath",
            "schema",
            "type",
            "user",
            "warehouse"
          ],
          "type": "object"
        }
      ]
    },
    "CronSchedule": {
      "description": "A cron expression in standard 5-field format (e.g. \"0 3 * * *\").",
      "format": "cron",
      "type": "string"
    },
    "DbtCloudSpec": {
      "description": "dbt Cloud configuration for pre-sync running-job checks.",
      "properties": {
        "credentialsFile": {
          "description": "Path to the dbt Cloud credentials file. Defaults to `~/.dbt/dbt_cloud.yml`.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "DefaultSync": {
      "description": "Override for the auto-generated Sync. Same interface as `onDrift` entries (sync name + with).",
      "properties": {
        "sync": {
          "description": "Name of the user-defined Sync resource to use instead of the auto-generated one.",
          "type": "string"
        },
        "with": {
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "description": "Template variables passed to the Sync and Conditions resources for argument interpolation.",
          "type": "object"
        }
      },
      "required": [
        "sync"
      ],
      "type": "object"
    },
    "DesiredCondition": {
      "description": "A single desired state condition. The Asset is Ready only when all conditions are satisfied. Each condition carries a `name` that is unique within the Asset (after Conditions expansion) and used as a key in execution logs.",
      "oneOf": [
        {
          "description": "Can transition to Not Ready as time passes beyond `maxAge`.",
          "properties": {
            "checkAt": {
              "anyOf": [
                {
                  "$ref": "#/definitions/CronSchedule"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional cron expression for additional evaluation at a specific time."
            },
            "column": {
              "description": "If omitted, freshness is determined from table metadata instead of a column value.",
              "type": [
                "string",
                "null"
              ]
            },
            "evaluateCacheTtl": {
              "anyOf": [
                {
                  "$ref": "#/definitions/Duration"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Per-condition cache TTL override. Takes precedence over the Asset-level default."
            },
            "interval": {
              "allOf": [
                {
                  "$ref": "#/definitions/Duration"
                }
              ],
              "description": "Polling interval for re-evaluating this condition."
            },
            "maxAge": {
              "allOf": [
                {
                  "$ref": "#/definitions/Duration"
                }
              ],
              "description": "Maximum acceptable age of the data before the condition becomes Not Ready."
            },
            "name": {
              "description": "Unique identifier for this condition within the Asset.",
              "type": "string"
            },
            "type": {
              "enum": [
                "Freshness"
              ],
              "type": "string"
            }
          },
          "required": [
            "interval",
            "maxAge",
            "name",
            "type"
          ],
          "type": "object"
        },
        {
          "description": "Query must return a scalar boolean. Ready when the result is true.",
          "properties": {
            "evaluateCacheTtl": {
              "anyOf": [
                {
                  "$ref": "#/definitions/Duration"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Per-condition cache TTL override. Takes precedence over the Asset-level default."
            },
            "interval": {
              "anyOf": [
                {
                  "$ref": "#/definitions/Duration"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Optional polling interval. If omitted, only evaluated on upstream state change or after sync."
            },
            "name": {
              "description": "Unique identifier for this condition within the Asset.",
              "type": "string"
            },
            "query": {
              "description": "SQL query that must return a scalar boolean.",
              "type": "string"
            },
            "type": {
              "enum": [
                "SQL"
              ],
              "type": "string"
            }
          },
          "required": [
            "name",
            "query",
            "type"
          ],
          "type": "object"
        },
        {
          "description": "Runs an external command. Ready when the process exits with code 0. `run` is argv: the first element is the program, the rest are arguments.",
          "properties": {
            "env": {
              "additionalProperties": {
                "type": "string"
              },
              "default": {},
              "description": "Environment variables to set for the subprocess.",
              "type": "object"
            },
            "evaluateCacheTtl": {
              "anyOf": [
                {
                  "$ref": "#/definitions/Duration"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Per-condition cache TTL override. Takes precedence over the Asset-level default."
            },
            "interval": {
              "anyOf": [
                {
                  "$ref": "#/definitions/Duration"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Optional polling interval. If omitted, only evaluated on upstream state change or after sync."
            },
            "name": {
              "description": "Unique identifier for this condition within the Asset.",
              "type": "string"
            },
            "run": {
              "description": "Command and arguments in argv format.",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "type": {
              "enum": [
                "Command"
              ],
              "type": "string"
            }
          },
          "required": [
            "name",
            "run",
            "type"
          ],
          "type": "object"
        }
      ]
    },
    "Duration": {
      "description": "A human-readable duration string (e.g. \"24h\", \"30m\", \"1h30m\").",
      "format": "duration",
      "type": "string"
    },
    "MergePosition": {
      "description": "Controls where an overlay onDrift entry is placed relative to Origin-generated entries during Asset overlay merge.",
      "enum": [
        "beforeOrigin",
        "afterOrigin"
      ],
      "type": "string"
    },
    "Metadata": {
      "description": "Common metadata shared by all resource kinds.",
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "OnDriftEntry": {
      "description": "An entry in `on_drift`. Pairs a Conditions reference with a Sync reference. The conditions are evaluated as a group (all must pass for no drift).",
      "properties": {
        "conditions": {
          "description": "Name of the `kind: Conditions` resource whose conditions define drift.",
          "type": "string"
        },
        "mergePosition": {
          "allOf": [
            {
              "$ref": "#/definitions/MergePosition"
            }
          ],
          "default": "beforeOrigin",
          "description": "Controls insertion position during overlay merge. Not included in compiled output."
        },
        "sync": {
          "description": "Name of the Sync resource to execute when drift is detected.",
          "type": "string"
        },
        "with": {
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "description": "Template variables passed to the Sync and Conditions resources for argument interpolation.",
          "type": "object"
        }
      },
      "required": [
        "conditions",
        "sync"
      ],
      "type": "object"
    },
    "OriginSpec": {
      "description": "Spec for `kind: Origin`. References an external project (e.g. dbt) to auto-generate Assets.",
      "oneOf": [
        {
          "properties": {
            "autoSync": {
              "default": null,
              "description": "Override `autoSync` for all auto-generated Assets. When `None`, each Asset uses its own default (`true`).",
              "type": [
                "boolean",
                "null"
              ]
            },
            "connection": {
              "description": "Connection resource name for auto-generated Assets.",
              "type": "string"
            },
            "defaultSync": {
              "anyOf": [
                {
                  "$ref": "#/definitions/DefaultSync"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "User-defined Sync to override the auto-generated `nagi-dbt-run`."
            },
            "projectDir": {
              "description": "Local path to the dbt project directory (relative or absolute).",
              "type": "string"
            },
            "type": {
              "enum": [
                "DBT"
              ],
              "type": "string"
            }
          },
          "required": [
            "connection",
            "projectDir",
            "type"
          ],
          "type": "object"
        }
      ]
    },
    "StepType": {
      "description": "Currently only `Command` (subprocess execution) is supported.",
      "enum": [
        "Command"
      ],
      "type": "string"
    },
    "SyncSpec": {
      "description": "Spec for `kind: Sync`. Defines convergence operations as a pre/run/post sequence of steps. Reusable across multiple Assets via `ref`.",
      "properties": {
        "post": {
          "anyOf": [
            {
              "$ref": "#/definitions/SyncStep"
            },
            {
              "type": "null"
            }
          ],
          "description": "Optional step executed after the main sync command."
        },
        "pre": {
          "anyOf": [
            {
              "$ref": "#/definitions/SyncStep"
            },
            {
              "type": "null"
            }
          ],
          "description": "Optional step executed before the main sync command."
        },
        "run": {
          "allOf": [
            {
              "$ref": "#/definitions/SyncStep"
            }
          ],
          "description": "The main convergence step."
        }
      },
      "required": [
        "run"
      ],
      "type": "object"
    },
    "SyncStep": {
      "properties": {
        "args": {
          "description": "Command and arguments in argv format.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "description": "Environment variables to set for the subprocess.",
          "type": "object"
        },
        "type": {
          "allOf": [
            {
              "$ref": "#/definitions/StepType"
            }
          ],
          "description": "Execution type for this step (currently only `Command`)."
        }
      },
      "required": [
        "args",
        "type"
      ],
      "type": "object"
    }
  },
  "description": "A Nagi resource. Dispatched by the `kind` field in YAML, following the Kubernetes CRD convention. Includes `apiVersion` to ensure the same YAML works in CLI, `nagi serve`, and future k8s environments.",
  "oneOf": [
    {
      "properties": {
        "apiVersion": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "Connection"
          ],
          "type": "string"
        },
        "metadata": {
          "$ref": "#/definitions/Metadata"
        },
        "spec": {
          "$ref": "#/definitions/ConnectionSpec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "type": "object"
    },
    {
      "properties": {
        "apiVersion": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "Asset"
          ],
          "type": "string"
        },
        "metadata": {
          "$ref": "#/definitions/Metadata"
        },
        "spec": {
          "$ref": "#/definitions/AssetSpec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "type": "object"
    },
    {
      "properties": {
        "apiVersion": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "Conditions"
          ],
          "type": "string"
        },
        "metadata": {
          "$ref": "#/definitions/Metadata"
        },
        "spec": {
          "$ref": "#/definitions/ConditionsSpec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "type": "object"
    },
    {
      "properties": {
        "apiVersion": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "Sync"
          ],
          "type": "string"
        },
        "metadata": {
          "$ref": "#/definitions/Metadata"
        },
        "spec": {
          "$ref": "#/definitions/SyncSpec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "type": "object"
    },
    {
      "properties": {
        "apiVersion": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "Origin"
          ],
          "type": "string"
        },
        "metadata": {
          "$ref": "#/definitions/Metadata"
        },
        "spec": {
          "$ref": "#/definitions/OriginSpec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "type": "object"
    }
  ],
  "title": "NagiKind"
}