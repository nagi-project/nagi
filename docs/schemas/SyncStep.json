{
  "$defs": {
    "Duration": {
      "description": "A human-readable duration string (e.g. \"24h\", \"30m\", \"1h30m\").",
      "format": "duration",
      "type": "string"
    },
    "StepType": {
      "description": "Currently only `Command` (subprocess execution) is supported.",
      "enum": [
        "Command"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "args": {
      "description": "Command and arguments in argv format.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "env": {
      "additionalProperties": {
        "type": "string"
      },
      "default": {},
      "description": "Environment variables to set for the subprocess.",
      "type": "object"
    },
    "identity": {
      "description": "Reference to a `kind: Identity` resource. Overrides the Sync-level identity for this stage.",
      "type": [
        "string",
        "null"
      ]
    },
    "timeout": {
      "anyOf": [
        {
          "$ref": "#/$defs/Duration"
        },
        {
          "type": "null"
        }
      ],
      "description": "Per-step timeout. Overrides the Sync-level `timeout` for this stage."
    },
    "type": {
      "$ref": "#/$defs/StepType",
      "description": "Execution type for this step (currently only `Command`)."
    }
  },
  "required": [
    "type",
    "args"
  ],
  "title": "SyncStep",
  "type": "object"
}