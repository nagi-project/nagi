{
  "outputStyle": "default",
  "spinnerTipsEnabled": false,
  "prefersReducedMotion": true,
  "permissions": {
    "allow": [
      "Bash(mise run:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push *)",
      "Bash(chmod 777 *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowRead": [
        "~/.cache/uv",
        "~/.cargo"
      ],
      "allowWrite": [
        "~/.cache/uv",
        "~/.cargo",
        "~/.local/state/mise",
        ".git"
      ],
      "denyRead": [
        "~/.aws/credentials",
        "~/.config/gcloud",
        "~/.ssh"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "*.githubusercontent.com",
        "pypi.org",
        "files.pythonhosted.org",
        "crates.io",
        "static.crates.io",
        "index.crates.io"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-commit-check.sh",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
